    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "croner": "^10.0.1",
    "nanoid": "^5.1.7",
